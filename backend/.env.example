# Supabase PostgreSQL (IPv4-friendly pooler — copy exact URIs from Dashboard → Connect)
# If the password has @ # % + & etc., URL-encode it in the URI (or use the dashboard “copy” button).
#
# Transaction pooler (app) + Session pooler (migrations) — example host for eu-west-3:
DATABASE_URL="postgresql://postgres.anpinwubiifhjblwppkq:[YOUR-PASSWORD]@aws-1-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.anpinwubiifhjblwppkq:[YOUR-PASSWORD]@aws-1-eu-west-3.pooler.supabase.com:5432/postgres"

PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Public web app URL (used for Flutterwave redirect after payment)
PUBLIC_APP_URL="http://localhost:3000"

# JWT — required; use a long random string in production
JWT_SECRET="change-me-in-production"
# Optional, e.g. 12h or 7d (default)
# JWT_EXPIRES_IN="7d"

# Flutterwave (test) — use Dashboard keys; never commit real .env
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK_TEST-xxxxxxxx"
FLUTTERWAVE_SECRET_KEY="FLWSECK_TEST-xxxxxxxx"
FLUTTERWAVE_ENCRYPTION_KEY="FLWSECK_TESTxxxxxxxx"
# From Flutterwave Dashboard → Settings → Webhooks → Secret hash (verif-hash header)
FLUTTERWAVE_SECRET_HASH=""

# Donate page: Rwanda MTN MoMo default amount (RWF); /api/donations/momo/initiate
# DONATION_DEFAULT_AMOUNT_RWF=1500
