# Supabase — copy pooler URIs from Dashboard → Connect
# App runtime (transaction pooler, port 6543 + pgbouncer)
DATABASE_URL="postgresql://..."
# Prisma CLI / migrations (session pooler port 5432). Falls back to DATABASE_URL in prisma.config.ts if unset.
DIRECT_URL="postgresql://..."

# Auth (required)
JWT_SECRET="long-random-string"
# JWT_EXPIRES_IN="7d"

# Public site URL (Flutterwave redirects + optional fallback)
# On Vercel you can set NEXT_PUBLIC_APP_URL to your deployment URL
PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Leave empty to call /api on the same origin (Next.js API routes)
NEXT_PUBLIC_API_URL=

NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx

FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxxxxx
FLUTTERWAVE_SECRET_HASH=

# DONATION_DEFAULT_AMOUNT_RWF=1500
